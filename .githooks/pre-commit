#!/usr/bin/env bash
# Run CRT sweep unit tests before every commit.
# Install once with: git config core.hooksPath .githooks

set -e

PYTHON="/Users/johnmcruz/Projects/algoTraderAI/venv/bin/python"
REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "Running unit tests..."

if ! "$PYTHON" -m pytest "$REPO_ROOT/tests/test_features_crt.py" -q; then
    echo ""
    echo "ERROR: Unit tests failed. Commit blocked."
    echo "Fix the failing tests and try again."
    exit 1
fi
