#!/usr/bin/env bash
# Run the FFM unit tests before every commit.
# Install once with: git config core.hooksPath .githooks

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
PYTHON="$REPO_ROOT/.venv/bin/python"

if [[ ! -x "$PYTHON" ]]; then
    echo "ERROR: FFM virtualenv is missing: $PYTHON"
    echo "Create .venv and install the project test dependencies before committing."
    exit 1
fi

echo "Running unit tests..."

if ! "$PYTHON" -m pytest "$REPO_ROOT/tests/" -q; then
    echo ""
    echo "ERROR: Unit tests failed. Commit blocked."
    echo "Fix the failing tests and try again."
    exit 1
fi
